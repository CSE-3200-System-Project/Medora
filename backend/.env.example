# ============================================================================
# SUPABASE DATABASE (Required)
# ============================================================================
# Format: postgresql+asyncpg://user:password@host:port/database
# Example: postgresql+asyncpg://postgres:password123@db.supabase.co:5432/postgres
SUPABASE_DATABASE_URL=postgresql+asyncpg://user:password@host:5432/database

# ============================================================================
# SUPABASE AUTH & STORAGE (Required)
# ============================================================================
# Your Supabase project URL
SUPABASE_URL=https://your-project.supabase.co

# Public/anon key used for Auth API calls
SUPABASE_KEY=your-anon-key-here

# Service role key used for backend-only storage/database privileged operations
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Storage bucket used by upload endpoints
SUPABASE_STORAGE_BUCKET=medora-storage

# ============================================================================
# GROQ AI SERVICE (Required for AI Doctor Search)
# ============================================================================
# Get from https://console.groq.com/
GROQ_API_KEY=your-groq-api-key-here

# Optional: override extraction model if needed
# GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# ============================================================================
# PRESCRIPTION EXTRACTION LOCAL TEST (Optional)
# ============================================================================
# Used by scripts/test_prescription_extraction.ps1
# For local backend: http://127.0.0.1:8000
BACKEND_BASE_URL=http://127.0.0.1:8000

# Do not store user session tokens in .env.
# Pass token at runtime to the script:
#   .\scripts\test_prescription_extraction.ps1 -AuthToken "<supabase_access_token>"
# Or run without -AuthToken and the script will prompt securely.

# Relative path from backend folder or absolute path to image file
TEST_PRESCRIPTION_IMAGE_PATH=test_prescription_sample.png

# true/false: save uploaded test file in Supabase storage
TEST_SAVE_FILE=false

# ============================================================================
# GOOGLE CALENDAR INTEGRATION (Optional)
# ============================================================================
# Get credentials from https://console.cloud.google.com/apis/credentials
# Required scopes: https://www.googleapis.com/auth/calendar.events
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/oauth/google/callback

# Frontend URL for OAuth redirects
FRONTEND_URL=http://localhost:3000

# ============================================================================
# CORS Configuration
# ============================================================================
# Comma-separated list of allowed origins
# Examples: http://localhost:3000,https://app.medora.com
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ============================================================================
# ADMIN CONFIGURATION
# ============================================================================
# Admin panel password (change in production!)
ADMIN_PASSWORD=admin123

# ============================================================================
# DEVELOPMENT/DEBUG
# ============================================================================
# Enable hot reload in Docker (set to 'true' for development)
RELOAD=false

# Container listen port (Azure Container Apps can override this)
PORT=8000

# Uvicorn worker processes (set based on CPU/memory)
UVICORN_WORKERS=1

# Keep true for normal startup; set false only if DB is managed externally at startup time
WAIT_FOR_DB=true

# Run Alembic migrations during container startup
RUN_MIGRATIONS=true

# Keep false for fast startup in cloud environments (Container Apps, App Service)
PRELOAD_WHISPER_ON_STARTUP=false

# ============================================================================
# NOTES:
# - Copy this file to .env and fill in actual values
# - Never commit .env file to git
# - For production, use Docker secrets or environment variable injection
# ============================================================================
