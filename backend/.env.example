# ============================================================================
# SUPABASE DATABASE (Required)
# ============================================================================
# Format: postgresql+asyncpg://user:password@host:port/database
# Example: postgresql+asyncpg://postgres:password123@db.supabase.co:5432/postgres
SUPABASE_DATABASE_URL=postgresql+asyncpg://user:password@host:5432/database

# ============================================================================
# SUPABASE AUTH & STORAGE (Required)
# ============================================================================
# Your Supabase project URL
SUPABASE_URL=https://your-project.supabase.co

# Public/anon key used for Auth API calls
SUPABASE_KEY=your-anon-key-here

# Service role key used for backend-only storage/database privileged operations
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Storage bucket used by upload endpoints
SUPABASE_STORAGE_BUCKET=medora-storage

# ============================================================================
# GROQ AI SERVICE (Required for AI Doctor Search)
# ============================================================================
# Get from https://console.groq.com/
GROQ_API_KEY=your-groq-api-key-here

# Optional: override extraction model if needed
# GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# ============================================================================
# VAPI VOICE AI (Optional - for Chorui voice integration)
# ============================================================================
# Public key and Assistant ID are used by frontend web voice calls.
VAPI_PUBLIC_KEY=
VAPI_ASSISTANT_ID=

# Optional server API key if you later automate assistant/tool creation from backend.
VAPI_API_KEY=

# Shared secret to validate incoming Vapi tool webhooks.
# If set, configure the same value as `x-vapi-tool-secret` header in your Vapi custom tool.
VAPI_TOOL_SHARED_SECRET=

# ============================================================================
# PRESCRIPTION EXTRACTION LOCAL TEST (Optional)
# ============================================================================
# Used by scripts/test_prescription_extraction.ps1
# For local backend: http://127.0.0.1:8000
BACKEND_BASE_URL=http://127.0.0.1:8000

# Do not store user session tokens in .env.
# Pass token at runtime to the script:
#   .\scripts\test_prescription_extraction.ps1 -AuthToken "<supabase_access_token>"
# Or run without -AuthToken and the script will prompt securely.

# Relative path from backend folder or absolute path to image file
TEST_PRESCRIPTION_IMAGE_PATH=test_prescription_sample.png

# true/false: save uploaded test file in Supabase storage
TEST_SAVE_FILE=false

# ============================================================================
# GOOGLE CALENDAR INTEGRATION (Optional)
# ============================================================================
# Get credentials from https://console.cloud.google.com/apis/credentials
# Required scopes: 
#   - openid (Google Sign-In / OpenID Connect)
#   - email (User email address)
#   - profile (User basic profile)
#   - https://www.googleapis.com/auth/calendar.events (Create/manage calendar events)
#   - https://www.googleapis.com/auth/calendar.readonly (Read calendar list - optional)
#
# Setup Steps:
# 1. Create a project in Google Cloud Console
# 2. Enable Google Calendar API
# 3. Configure OAuth consent screen (add scopes above)
# 4. Create OAuth 2.0 credentials (Web application type)
# 5. Add authorized redirect URI: http://localhost:8000/oauth/google/callback (dev)
#    or https://your-domain.com/oauth/google/callback (production)
# 6. Copy Client ID and Client Secret below

GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/oauth/google/callback

# Frontend URL for OAuth redirects
FRONTEND_URL=http://localhost:3000

# ============================================================================
# CORS Configuration
# ============================================================================
# Comma-separated list of allowed origins
# Examples: http://localhost:3000,https://app.medora.com
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ============================================================================
# ADMIN CONFIGURATION
# ============================================================================
# Admin panel password (change in production!)
ADMIN_PASSWORD=admin123

# ============================================================================
# DEVELOPMENT/DEBUG
# ============================================================================
# Enable hot reload in Docker (set to 'true' for development)
RELOAD=false

# Container listen port (Azure Container Apps can override this)
PORT=8000

# Uvicorn worker processes (set based on CPU/memory)
UVICORN_WORKERS=1

# Keep true for normal startup; set false only if DB is managed externally at startup time
WAIT_FOR_DB=true

# Run Alembic migrations during container startup
RUN_MIGRATIONS=true

# Keep false for fast startup in cloud environments (Container Apps, App Service)
PRELOAD_WHISPER_ON_STARTUP=false

# Reminder dispatcher
REMINDER_DISPATCH_ENABLED=true
REMINDER_DISPATCH_INTERVAL_SECONDS=30
REMINDER_LEAD_MINUTES=15
DEFAULT_REMINDER_TIMEZONE=Asia/Dhaka

# Web push (for PWA background notifications)
WEB_PUSH_VAPID_PUBLIC_KEY=your-web-push-vapid-public-key
WEB_PUSH_VAPID_PRIVATE_KEY=your-web-push-vapid-private-key
WEB_PUSH_VAPID_SUBJECT=mailto:notifications@medora.app

# Account moderation support + SMTP email
SUPPORT_EMAIL=support@medora.com
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=your-smtp-username
SMTP_PASSWORD=your-smtp-password
SMTP_FROM_EMAIL=no-reply@medora.com
# Set exactly one transport mode depending on provider:
# - Port 587: SMTP_USE_TLS=true, SMTP_USE_SSL=false
# - Port 465: SMTP_USE_TLS=false, SMTP_USE_SSL=true
SMTP_USE_TLS=true
SMTP_USE_SSL=false
SMTP_TIMEOUT_SECONDS=20

# ============================================================================
# NOTES:
# - Copy this file to .env and fill in actual values
# - Never commit .env file to git
# - For production, use Docker secrets or environment variable injection
# ============================================================================
